            "nodes": [
              {
                "id": "8rdid11",
                "data": {
                  "code": "(async () => {\n  const sleep = (ms) => new Promise(r => setTimeout(r, ms));\n\n  const simulateClick = (element) => {\n    if (!element) return;\n    element.dispatchEvent(new PointerEvent('pointerdown', { bubbles: true, cancelable: true, view: window }));\n    element.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));\n    element.dispatchEvent(new PointerEvent('pointerup', { bubbles: true, cancelable: true, view: window }));\n    element.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));\n    element.click();\n  };\n\n  const simulateInput = (element, text) => {\n    if (!element) return;\n    element.focus();\n    const nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, \"value\").set;\n    if (nativeInputValueSetter) {\n      nativeInputValueSetter.call(element, text);\n    } else {\n      element.value = text;\n    }\n    element.dispatchEvent(new Event('input', { bubbles: true }));\n  };\n\n  const getSelect = (id) => {\n    const input = document.querySelector(`#${id}`);\n    return input ? input.closest('.ant-select').querySelector('.ant-select-selector') : null;\n  };\n\n  const selectOption = async (id, targetValue, maxRetries = 20) => {\n    const selector = getSelect(id);\n    if (!selector) {\n      console.log(`[QC Automa] Not found selector for ${id}`);\n      return;\n    }\n\n    // Mở dropdown\n    simulateClick(selector);\n    await sleep(300);\n\n    // Gõ text vào ô search nếu có targetValue để kích hoạt API search\n    if (targetValue && targetValue.trim() !== '') {\n      const searchInput = selector.parentElement.querySelector('.ant-select-selection-search-input');\n      if (searchInput) {\n        simulateInput(searchInput, targetValue.trim());\n        await sleep(1000); // Chờ API\n      }\n    }\n\n    // Chờ Dropdown load xong\n    let options = [];\n    for (let i = 0; i < maxRetries; i++) {\n      const dropdownContainer = document.querySelector(`#${id}_list`)?.closest('.ant-select-dropdown');\n      if (dropdownContainer) {\n        const found = Array.from(dropdownContainer.querySelectorAll('.ant-select-item-option'))\n          .filter(opt => !opt.classList.contains('ant-select-item-option-disabled') && !opt.getAttribute('aria-disabled'));\n        if (found.length > 0) {\n          options = found;\n          break;\n        }\n      }\n      await sleep(500);\n    }\n\n    if (options.length === 0) {\n      console.error(`[QC Automa] Timeout waiting for select option in ${id}`);\n      throw new Error(\"No options found\");\n    }\n\n    let chosenOption = null;\n    if (targetValue && targetValue.trim() !== '') {\n      const targetLower = targetValue.toLowerCase().trim();\n      chosenOption = options.find(opt => \n        (opt.innerText && opt.innerText.toLowerCase().includes(targetLower)) || \n        (opt.getAttribute('label') && opt.getAttribute('label').toLowerCase().includes(targetLower)) ||\n        (opt.getAttribute('ldap') && opt.getAttribute('ldap').toLowerCase() === targetLower)\n      );\n    }\n\n    if (!chosenOption) {\n      chosenOption = options[Math.floor(Math.random() * options.length)];\n      console.log(`[QC Automa] ${id} fallback random:`, chosenOption.innerText);\n    } else {\n      console.log(`[QC Automa] ${id} đã chọn đúng Data QC:`, chosenOption.innerText);\n    }\n\n    simulateClick(chosenOption);\n    await sleep(500); // Chờ hiệu ứng select\n  };\n\n  try {\n    const getSafeParam = (paramString) => {\n      return (paramString && !paramString.includes('{{$params.')) ? paramString.trim() : '';\n    };\n\n    const qcName     = getSafeParam(`{{$params.teamName}}`);\n    const qcDivision = getSafeParam(`{{$params.division}}`);\n    const qcUnit     = getSafeParam(`{{$params.unit}}`);\n    const qcMarket   = getSafeParam(`{{$params.market}}`);\n    const qcLeader   = getSafeParam(`{{$params.leader}}`);\n\n    const nameInput = document.querySelector('[data-test-id=\"team-create-name-input\"]');\n    if (nameInput) {\n      let teamName = qcName;\n      if (teamName === '') {\n        const randomSuffix = Math.random().toString(36).substring(2, 7).toUpperCase();\n        const randomNum = Math.floor(10 + Math.random() * 90);\n        teamName = `Team ${randomSuffix} ${randomNum}`;\n      }\n      simulateInput(nameInput, teamName);\n      await sleep(300);\n    }\n\n    await selectOption('form_item_divisionCode', qcDivision);\n    await selectOption('form_item_departmentCode', qcUnit);\n    await selectOption('form_item_marketCode', qcMarket);\n    await selectOption('form_item_leaderLdap', qcLeader);\n\n    automaNextBlock();\n  } catch (error) {\n    console.error('[QC Automa] JS Execution Error:', error);\n    automaNextBlock({ $error: true });\n  }\n})();",
                  "context": "website",
